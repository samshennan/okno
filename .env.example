# Okno environment variables
# Copy this to .env and fill in your values.

# Google OAuth credentials — see docs/GOOGLE-OAUTH-SETUP.md
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Port the app listens on (default 3100)
PORT=3100

# Node environment
NODE_ENV=production

# Optional: restrict sign-in to specific Google accounts.
# Comma-separated list of email addresses, case-insensitive.
# Leave unset (or empty) to allow any Google account.
# ALLOWED_EMAILS=you@gmail.com,partner@gmail.com
